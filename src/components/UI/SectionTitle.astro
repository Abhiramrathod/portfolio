---
interface Props {
  title: string;
  align?: "left" | "center";
}

const { title, align = "left" } = Astro.props;
const isCenter = align === "center";
---

<div class:list={["mb-12 reveal-up", { "text-center": isCenter }]}>
  <span class="font-script text-lg text-primary-light">&lt; {title} /&gt;</span>
  <h2 class="mt-1 font-display text-3xl font-bold text-white md:text-4xl lg:text-5xl">
    {title}
  </h2>
  <div
    class:list={[
      "mt-3 h-1 w-20 rounded-full bg-gradient-to-r from-primary to-accent",
      { "mx-auto": isCenter },
    ]}
  />
</div>
